{
  "name": "skrt",
  "version": "0.3.0",
  "description": "Blazing-fast CLI + SKILL router for AI agents. Local skill discovery first, optional API reranking.",
  "author": "skrt-dev",
  "license": "MIT",
  "repository": "https://github.com/skrt-dev/skill-router",
  "keywords": [
    "skill-router",
    "agent-skills",
    "skill-discovery",
    "SKILL.md",
    "claude-code",
    "codex",
    "cursor",
    "gemini-cli",
    "antigravity",
    "meta-skill",
    "productivity"
  ],
  "compatibility": [
    "claude-code",
    "codex-cli",
    "cursor",
    "gemini-cli",
    "antigravity",
    "openclaw",
    "cline",
    "windsurf"
  ],
  "install": {
    "requires": ["go>=1.21"],
    "commands": [
      "git clone https://github.com/skrt-dev/skill-router.git",
      "cd skill-router && make install",
      "skrt index"
    ]
  },
  "skill_path": "SKILL.md"
}
